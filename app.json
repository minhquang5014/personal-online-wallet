{
  "expo": {
    "name": "Quản lý chi tiêu",
    "slug": "personal-finance-management",
    "version": "1.0.0",
    "scheme": "pfm",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minhquang5014.personalwallet"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
