{
  "expo": {
    "name": "Quản lý chi tiêu",
    "slug": "chi-tieu-gia-dinh",
    "version": "1.0.0",
    "scheme": "pfm",
    "orientation": "portrait",
    "icon": "./assets/logo-app.jpg",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minhquang5014.personalwallet"
    },
    "web": {
      "favicon": "./assets/logo-app.jpg",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9267cd39-ecda-4646-9eff-24a4d598501f"
      }
    },
    "owner": "d25m12"
  }
}
